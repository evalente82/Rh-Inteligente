#     cp .env.example .env
# ============================================================

ASPNETCORE_ENVIRONMENT=Development

# ── DEVELOPMENT ──────────────────────────────────────────────
DEV_POSTGRES_HOST=localhost
DEV_POSTGRES_PORT=5435
DEV_POSTGRES_DATABASE=vcorp_rh_dev
DEV_POSTGRES_USERNAME=vcorp
DEV_POSTGRES_PASSWORD=

DEV_GEMINI_API_KEY=
DEV_GEMINI_MODEL=gemini-2.5-flash

DEV_QDRANT_HOST=localhost
DEV_QDRANT_PORT=6334
DEV_QDRANT_PREFIX=dev

# ── PRODUCTION ───────────────────────────────────────────────
PROD_POSTGRES_HOST=
PROD_POSTGRES_PORT=5432
PROD_POSTGRES_DATABASE=vcorp_rh_prod
PROD_POSTGRES_USERNAME=vcorp
PROD_POSTGRES_PASSWORD=

PROD_GEMINI_API_KEY=
PROD_GEMINI_MODEL=gemini-2.5-flash

PROD_QDRANT_HOST=localhost
PROD_QDRANT_PORT=6334
PROD_QDRANT_PREFIX=prod
